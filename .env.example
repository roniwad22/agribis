# ── Agri-Bridge Micro-Aggregator OS ──
# Copy this to .env and fill in your values

# Server
PORT=3000
NODE_ENV=production

# Database (SQLite path — use /data/agribis.db in Docker)
DB_PATH=./agribis.db

# Admin secret — required for admin panel access
ADMIN_SECRET=change-me-to-a-strong-secret

# Africa's Talking SMS (leave blank to disable SMS)
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=AgriBridge

# MoMo sandbox flag (set to "true" to auto-advance escrow on create)
SANDBOX=true

# Discord webhook for alerts (optional)
DISCORD_WEBHOOK_URL=

# Seed mode — set to "true" to load demo data on first boot
SEED_DEMO=false
